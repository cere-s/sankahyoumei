# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# サイトURL（本番デプロイ時に設定。未設定時は VERCEL_URL → localhost:3000）
NEXT_PUBLIC_SITE_URL=

# 通報メール（Resend）
# https://resend.com でAPIキーを発行
RESEND_API_KEY=
# 通報の送信先メールアドレス（非公開。NEXT_PUBLIC を付けないこと）
REPORT_EMAIL_TO=
# 送信元アドレス。独自ドメイン未設定なら onboarding@resend.dev
REPORT_EMAIL_FROM=onboarding@resend.dev
# お問い合わせの送信先（任意。未設定なら REPORT_EMAIL_TO を使用）
CONTACT_EMAIL_TO=

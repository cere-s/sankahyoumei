# Supabase
NEXT_PUBLIC_SUPABASE_URL=
# 公開クライアントキー（anon もしくは publishable のどちらか）
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# サイトURL（本番デプロイ時に設定。未設定時は VERCEL_URL → localhost:3000）
NEXT_PUBLIC_SITE_URL=

# デモ版モード。true にするとサンプルデータ＋デモログインで動作し、Supabase/Xログインを使わない。
# デモ用の別 Vercel プロジェクトでのみ true にする（本番は未設定/false）。
# 問い合わせメールだけは実送信するため、デモ環境にも RESEND_API_KEY と送信先を設定する。
NEXT_PUBLIC_DEMO_MODE=

# Server-only. Do not expose to browser.
SUPABASE_SERVICE_ROLE_KEY=

# X / Twitter OAuth 2.0 は Supabase Dashboard の Auth Provider 設定に保存します。
# Client Secret は Next.js / Vercel の環境変数には置かないでください（ブラウザに出さない）。
# X_CLIENT_ID=
# X_CLIENT_SECRET=

# 通報・お問い合わせメール（Resend）
# https://resend.com でAPIキーを発行
RESEND_API_KEY=
# 通報の送信先メールアドレス（非公開。NEXT_PUBLIC を付けないこと）
REPORT_EMAIL_TO=
# 送信元アドレス。独自ドメイン未設定なら onboarding@resend.dev
REPORT_EMAIL_FROM=onboarding@resend.dev
# お問い合わせの送信先（任意。未設定なら REPORT_EMAIL_TO を使用）
CONTACT_EMAIL_TO=

# 画像アップロード（Cloudflare R2 / S3互換）。すべてサーバー専用。クライアントに出さない。
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# 公開配信URL（R2のパブリックバケット or 独自ドメイン）。例: https://img.example.com
R2_PUBLIC_BASE_URL=

# 管理者の Supabase Auth ユーザーID（UUID）。カンマ区切り。
# 任意の画像を削除可能。加えて /admin/analytics（アクセス解析）の閲覧もこのIDのみ許可される。
ADMIN_USER_IDS=

# OGP画像の一括再生成エンドポイント /api/admin/refresh-og の秘密キー。
# 任意の長いランダム文字列。Vercel と、スクリプト実行環境(.env.local)に同じ値を設定する。
OG_REFRESH_SECRET=
